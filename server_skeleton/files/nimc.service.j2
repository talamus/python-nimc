[Unit]
Description={{ server_title }} Service
After=network.target

[Service]
Type=forking
User={{ service_username }}
PIDFile=/run/nimc/server.pid
ExecStart=/persistent/bin/start_server
ExecStop=/persistent/bin/stop_server
SuccessExitStatus=0 1
Restart=on-failure
RestartSec=10
PrivateTmp=true
WorkingDirectory=/persistent/server

[Install]
WantedBy=multi-user.target
